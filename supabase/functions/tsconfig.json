{
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "allowJs": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "stripe": ["../import_map.json"],
      "supabase-js": ["../import_map.json"],
      "std/": ["../import_map.json"]
    },
    "resolveJsonModule": true
  }
}